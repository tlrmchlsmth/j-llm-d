BASE_URL := "${BASE_URL}"
NAMESPACE := "${NAMESPACE}"
GRAFANA_URL := "http://grafana.vllm.svc.cluster.local"

# Use this Justfile within the cluster.

# Mark start of benchmark runs in Grafana (includes deployment configs)
_annotate MESSAGE:
  /app/annotate.sh "{{MESSAGE}}" "{{BASE_URL}}" "{{NAMESPACE}}" "{{GRAFANA_URL}}"

# Mark end of benchmark runs in Grafana (no configs, just the message)
_annotate_end MESSAGE:
  /app/annotate.sh "{{MESSAGE}}" "{{BASE_URL}}" "{{NAMESPACE}}" "{{GRAFANA_URL}}" skip

default:
  just --list

# Detect model from vLLM endpoint
@_model:
  #!/usr/bin/env bash
  RESP=$(curl -s {{BASE_URL}}/v1/models)
  MODEL=$(echo "$RESP" | jq -r '.data[0].id' 2>/dev/null)
  if [[ -z "$MODEL" || "$MODEL" == "null" ]]; then
    echo "ERROR: Could not detect model. Response: $RESP" >&2
    exit 1
  fi
  echo "$MODEL"

eval:
    .lm_eval/bin/lm_eval --model local-completions --tasks gsm8k \
    --model_args model=$(just _model),base_url={{BASE_URL}}/v1/completions,num_concurrent=2000,max_retries=3,tokenized_requests=False \
    --num_fewshot 10 \

benchmark RR MC NUM_REQUESTS INPUT_LEN OUTPUT_LEN:
    #!/usr/bin/env bash
    just _annotate "just benchmark {{RR}} {{MC}} {{NUM_REQUESTS}} {{INPUT_LEN}} {{OUTPUT_LEN}}"

    # Run benchmark and capture output
    BENCHMARK_OUTPUT=$(vllm bench serve \
        --base-url {{BASE_URL}} \
        --model $(just _model) \
        --dataset-name random \
        --random-input-len {{INPUT_LEN}} \
        --random-output-len {{OUTPUT_LEN}}  \
        --max-concurrency {{MC}} \
        --request-rate {{RR}} \
        --seed $(date +%M%H%M%S) \
        --num-prompts {{NUM_REQUESTS}} \
        --ignore-eos 2>&1 | tee /dev/tty | sed -n '/Serving Benchmark Result/,/^==*$/p')

    # Include results in end annotation
    END_MSG="BENCHMARK RESULTS - just benchmark {{RR}} {{MC}} {{NUM_REQUESTS}} {{INPUT_LEN}} {{OUTPUT_LEN}}"$'\n\n'"$BENCHMARK_OUTPUT"
    just _annotate_end "$END_MSG"

# Run N waves of X concurrent requests (wraps `benchmark`)
# Usage: just benchmark-a RR N X INPUT_LEN OUTPUT_LEN
# Optional: set OUTFILE=/path/to/log to control the log destination.
benchmark-a RR N X INPUT_LEN OUTPUT_LEN:
    N_X=$(( {{N}} * {{X}} ))
    outfile="${OUTFILE:-run_benchmark_{{N}}x{{X}}_$(date +%Y%m%d_%H%M%S).log}"
    just benchmark "{{RR}}" "{{X}}" "$N_X" "{{INPUT_LEN}}" "{{OUTPUT_LEN}}" |& tee "$outfile"

benchmark_sharegpt RR MC NUM_REQUESTS:
    #!/usr/bin/env bash
    DATASET="ShareGPT_V3_unfiltered_cleaned_split.json"
    if [[ ! -f "$DATASET" ]]; then
      echo "Downloading $DATASET..."
      curl -L -o "$DATASET" https://huggingface.co/datasets/anon8231489123/ShareGPT_Vicuna_unfiltered/resolve/main/$DATASET
    fi
    just _annotate "just benchmark_sharegpt {{RR}} {{MC}} {{NUM_REQUESTS}}"

    BENCHMARK_OUTPUT=$(vllm bench serve \
        --base-url {{BASE_URL}} \
        --model $(just _model) \
        --dataset-name sharegpt \
        --dataset-path "$DATASET" \
        --max-concurrency {{MC}} \
        --request-rate {{RR}} \
        --seed $(date +%M%H%M%S) \
        --num-prompts {{NUM_REQUESTS}} \
        --ignore-eos 2>&1 | tee /dev/tty | sed -n '/Serving Benchmark Result/,/^==*$/p')

    END_MSG="BENCHMARK RESULTS - just benchmark_sharegpt {{RR}} {{MC}} {{NUM_REQUESTS}}"$'\n\n'"$BENCHMARK_OUTPUT"
    just _annotate_end "$END_MSG"

benchmark_g MC NUM_REQUESTS INPUT_LEN OUTPUT_LEN:
  #!/usr/bin/env bash
  just _annotate "just benchmark_g {{MC}} {{NUM_REQUESTS}} {{INPUT_LEN}} {{OUTPUT_LEN}}"
  GUIDELLM__REQUEST_TIMEOUT="900" \
  GUIDELLM__MAX_CONCURRENCY="{{MC}}" \
    guidellm benchmark \
      --target {{BASE_URL}} \
      --rate-type constant \
      --rate 2048 \
      --max-requests {{NUM_REQUESTS}} \
      --data '{"prompt_tokens": {{INPUT_LEN}}, "output_tokens": {{OUTPUT_LEN}}}' \
  && just _annotate_end "END: just benchmark_g {{MC}} {{NUM_REQUESTS}} {{INPUT_LEN}} {{OUTPUT_LEN}}"

# Simulates a pure decode workload, for measuring output token throughput and TTFT.
# Designed to approximate the decode side of a P/D deployment in a steady state.
benchmark_decode_workload NUM_REQUESTS OUTPUT_LEN:
    #!/usr/bin/env bash
    just _annotate "just benchmark_decode_workload {{NUM_REQUESTS}} {{OUTPUT_LEN}}" \
    && vllm bench serve \
        --base-url {{BASE_URL}} \
        --model $(just _model) \
        --dataset-name random \
        --random-input-len 1 \
        --random-output-len {{OUTPUT_LEN}}  \
        --seed $(date +%M%H%M%S) \
        --num-prompts {{NUM_REQUESTS}} \
        --ignore-eos \
    && just _annotate_end "END: just benchmark_decode_workload {{NUM_REQUESTS}} {{OUTPUT_LEN}}"

# For hitting an individual vLLM instance while deploying a P/D setup
benchmark_no_pd POD_IP RR NUM_REQUESTS INPUT_LEN OUTPUT_LEN:
    #!/usr/bin/env bash
    just _annotate "just benchmark_no_pd {{POD_IP}} {{RR}} {{NUM_REQUESTS}} {{INPUT_LEN}} {{OUTPUT_LEN}}" \
    && vllm bench serve \
        --base-url http://{{POD_IP}}:8000 \
        --model $(just _model) \
        --dataset-name random \
        --random-input-len {{INPUT_LEN}} \
        --random-output-len {{OUTPUT_LEN}}  \
        --request-rate {{RR}} \
        --seed $(date +%M%H%M%S) \
        --num-prompts {{NUM_REQUESTS}} \
        --ignore-eos \
    && just _annotate_end "END: just benchmark_no_pd {{POD_IP}} {{RR}} {{NUM_REQUESTS}} {{INPUT_LEN}} {{OUTPUT_LEN}}"

# For vLLM PyTorch traces.
# vLLM serve must be run with the VLLM_TORCH_PROFILER_DIR env set.
start_profile URL:
  curl -X POST {{URL}}/start_profile
stop_profile URL:
  curl -X POST {{URL}}/stop_profile
profile URL:
  just start_profile {{URL}} \
  && sleep 1 \
  && just stop_profile {{URL}}

# Profile all decode pods (detected at runtime via kubectl)
profile_all_decode:
  #!/usr/bin/env bash
  set -euo pipefail

  echo "Detecting decode pods..."
  DECODE_IPS=$(kubectl get pods -n {{NAMESPACE}} -o json | jq -r '.items[] | select(.metadata.name | contains("decode")) | .status.podIP' | tr '\n' ' ')

  if [[ -z "$DECODE_IPS" ]]; then
    echo "No decode pods found in namespace {{NAMESPACE}}"
    exit 1
  fi

  echo "Decode pod IPs: $DECODE_IPS"
  echo "Starting profile on all decode pods asynchronously..."

  for IP in $DECODE_IPS; do
    echo "  Starting profile on $IP..."
    curl -s -X POST http://$IP:8200/start_profile &
  done
  wait

  echo "All decode pods started profiling"
  echo "Sleeping for 1 second..."
  sleep 1

  echo "Stopping profile on all decode pods asynchronously..."
  for IP in $DECODE_IPS; do
    echo "  Stopping profile on $IP..."
    curl -s -X POST http://$IP:8200/stop_profile &
  done
  wait

  echo "Profiling complete on all decode pods!"
