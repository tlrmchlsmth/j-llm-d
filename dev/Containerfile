FROM vllm/vllm-openai:cu130-nightly

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -y \
    && apt-get install -y --no-install-recommends ccache \
    && rm -rf /var/lib/apt/lists/*

ENV TORCH_CUDA_ARCH_LIST="9.0a;10.0+PTX" \
    UV_LINK_MODE=copy \
    UV_HTTP_TIMEOUT=500

# Install vLLM build requirements not present in the runtime image
RUN uv pip install --system cmake ninja \
    "setuptools>=77.0.3,<81.0.0" \
    "setuptools-scm>=8" \
    wheel "jinja2>=3.1.6" \
    "grpcio-tools==1.78.0"

CMD ["sleep", "infinity"]
