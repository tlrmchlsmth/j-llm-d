set dotenv-load
set dotenv-path := "../.env"

NAMESPACE := "tms"
KN := "kubectl -n " + NAMESPACE

# Benchmark configuration
MODEL := "openai/gpt-oss-120b"
#IMAGE := "ghcr.io/vcave/llm-d/llm-d-rocm:v0.4.6-debug"
IMAGE := "quay.io/tms/llm-d-dev-rocm:0.4.0-5e95fbe"
GPU_MEM_UTIL := "0.95"
TARGET_DURATION := "60"
MIN_PROMPTS := "200"
HF_CACHE := "/mnt/local/hf-cache"

# EP/DP sweep configuration
ENABLE_EP := "false"   # Enable --enable-expert-parallel (used by bench, always on for bench-ep/bench-dp)
MAX_GPU := "8"         # Max GPUs per job (limited by GPUs per node)

# Prefill workload
PREFILL_ISL := "4096"
PREFILL_OSL := "1"
PREFILL_CONCURRENCIES := "1 4 8 16"

# Decode workload
DECODE_ISL := "4096"
DECODE_OSL := "512"
DECODE_CONCURRENCIES := "4 16 32 64 128 256 512"

# Aggregated workload (actual ISL/OSL, no P/D specialization)
AGG_ISL := "4096"
AGG_OSL := "512"
AGG_CONCURRENCIES := "1 4 8 16 32 64"

default:
  just --list

# Launch a single benchmark Job
_job JOB_NAME GPU_COUNT TP DP ENABLE_EP WORKLOAD_TYPE ISL OSL CONCURRENCY_LEVELS:
  env \
    JOB_NAME={{JOB_NAME}} \
    GPU_COUNT={{GPU_COUNT}} \
    TP={{TP}} \
    DP={{DP}} \
    ENABLE_EP={{ENABLE_EP}} \
    MODEL="{{MODEL}}" \
    VLLM_IMAGE="{{IMAGE}}" \
    WORKLOAD_TYPE={{WORKLOAD_TYPE}} \
    ISL={{ISL}} \
    OSL={{OSL}} \
    CONCURRENCY_LEVELS="{{CONCURRENCY_LEVELS}}" \
    TARGET_DURATION={{TARGET_DURATION}} \
    MIN_PROMPTS={{MIN_PROMPTS}} \
    GPU_MEM_UTIL={{GPU_MEM_UTIL}} \
    HF_CACHE_HOST_PATH="{{HF_CACHE}}" \
    envsubst '${JOB_NAME} ${GPU_COUNT} ${TP} ${DP} ${ENABLE_EP} ${MODEL} ${VLLM_IMAGE} ${WORKLOAD_TYPE} ${ISL} ${OSL} ${CONCURRENCY_LEVELS} ${TARGET_DURATION} ${MIN_PROMPTS} ${GPU_MEM_UTIL} ${HF_CACHE_HOST_PATH}' \
      < job.yaml | {{KN}} apply -f -

# Launch TP sweep Jobs (prefill + decode at TP=1,2,4,8, DP=1, EP configurable)
bench:
  {{KN}} delete jobs -l app=pd-config-bench,pd-config/workload=prefill --ignore-not-found=true 2>/dev/null
  {{KN}} delete jobs -l app=pd-config-bench,pd-config/workload=decode --ignore-not-found=true 2>/dev/null
  just _job pd-config-prefill-tp1 1 1 1 {{ENABLE_EP}} prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
  just _job pd-config-prefill-tp2 2 2 1 {{ENABLE_EP}} prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
  just _job pd-config-prefill-tp4 4 4 1 {{ENABLE_EP}} prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
  just _job pd-config-prefill-tp8 8 8 1 {{ENABLE_EP}} prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
  just _job pd-config-decode-tp1 1 1 1 {{ENABLE_EP}} decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"
  just _job pd-config-decode-tp2 2 2 1 {{ENABLE_EP}} decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"
  just _job pd-config-decode-tp4 4 4 1 {{ENABLE_EP}} decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"
  just _job pd-config-decode-tp8 8 8 1 {{ENABLE_EP}} decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"

# Launch DP sweep Jobs (multiple vLLM instances, EP on, fixed TP)
bench-dp:
  #!/usr/bin/env bash
  set -euo pipefail
  {{KN}} delete jobs -l app=pd-config-bench,pd-config/workload=prefill --ignore-not-found=true 2>/dev/null
  {{KN}} delete jobs -l app=pd-config-bench,pd-config/workload=decode --ignore-not-found=true 2>/dev/null
  for DP in 1 2 4 8; do
    just _job "pd-config-prefill-dp${DP}" $DP 1 $DP true prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
    just _job "pd-config-decode-dp${DP}" $DP 1 $DP true decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"
  done

# Launch aggregated benchmark Jobs (actual workload, no P/D specialization)
bench-agg:
  {{KN}} delete jobs -l app=pd-config-bench,pd-config/workload=aggregated --ignore-not-found=true 2>/dev/null
  just _job pd-config-agg-tp1 1 1 1 {{ENABLE_EP}} aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"
  just _job pd-config-agg-tp2 2 2 1 {{ENABLE_EP}} aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"
  just _job pd-config-agg-tp4 4 4 1 {{ENABLE_EP}} aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"
  just _job pd-config-agg-tp8 8 8 1 {{ENABLE_EP}} aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"

# Launch all TP×DP combos (EP on, all workloads, constrained by MAX_GPU per node)
bench-full:
  #!/usr/bin/env bash
  set -euo pipefail
  {{KN}} delete jobs -l app=pd-config-bench --ignore-not-found=true 2>/dev/null
  COUNT=0
  for TP in 1 2 4 8; do
    for DP in 1 2 4 8; do
      GPU_COUNT=$((TP * DP))
      # Enable EP if using DP
      if [ $DP -neq 1 ]; then EP=true; else EP=false; fi
      if [ $GPU_COUNT -le {{MAX_GPU}} ]; then
        just _job "pd-config-prefill-tp${TP}dp${DP}" $GPU_COUNT $TP $DP $EP prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
        just _job "pd-config-decode-tp${TP}dp${DP}" $GPU_COUNT $TP $DP $EP decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"
        just _job "pd-config-agg-tp${TP}dp${DP}" $GPU_COUNT $TP $DP $EP aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"
        COUNT=$((COUNT + 3))
      fi
    done
  done
  echo "Launched $COUNT jobs ($(( COUNT / 3 )) TP×DP configs × 3 workloads)"

# Launch all benchmarks (P/D sweep + aggregated)
bench-all:
  just bench
  just bench-agg

# Wait for all benchmark Jobs to complete
wait:
  #!/usr/bin/env bash
  set -euo pipefail
  echo "Waiting for all pd-config benchmark jobs to complete..."
  for job in $({{KN}} get jobs -l app=pd-config-bench -o jsonpath='{.items[*].metadata.name}'); do
    echo "  Waiting for $job..."
    {{KN}} wait --for=condition=complete --timeout=3h "job/$job" || \
      echo "  WARNING: $job did not complete successfully"
  done
  echo "All jobs finished."

# Collect results from completed Jobs and generate CSVs
collect:
  python3 collect.py -n {{NAMESPACE}}

# Collect results and upload to Google Sheets with Pareto charts
collect-sheets TITLE="PD Config Benchmark Results":
  python3 collect.py -n {{NAMESPACE}} --sheets "{{TITLE}}"

# Show status of benchmark Jobs and Pods
status:
  {{KN}} get jobs -l app=pd-config-bench

# Clean up all benchmark Jobs
clean:
  {{KN}} delete jobs -l app=pd-config-bench --ignore-not-found=true 2>/dev/null
