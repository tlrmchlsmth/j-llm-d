set dotenv-load
set dotenv-path := "../.env"

NAMESPACE := "tms"
KN := "kubectl -n " + NAMESPACE

# Benchmark configuration
MODEL := "openai/gpt-oss-120b"
IMAGE := "ghcr.io/vcave/llm-d/llm-d-rocm:v0.4.6-debug"
GPU_MEM_UTIL := "0.95"
TARGET_DURATION := "60"
MIN_PROMPTS := "200"
HF_CACHE := "/mnt/local/hf-cache"
MAX_NODES := ""

# Prefill workload
PREFILL_ISL := "4096"
PREFILL_OSL := "1"
PREFILL_CONCURRENCIES := "1 4 8 16"

# Decode workload
DECODE_ISL := "4096"
DECODE_OSL := "512"
DECODE_CONCURRENCIES := "4 16 32 64 128 256 512"

# Aggregated workload (actual ISL/OSL, no P/D specialization)
AGG_ISL := "4096"
AGG_OSL := "512"
AGG_CONCURRENCIES := "1 4 8 16 32 64"

default:
  just --list

# Label GPU nodes for benchmark scheduling (honors MAX_NODES)
_setup-nodes:
  #!/usr/bin/env bash
  set -euo pipefail
  # Clear previous labels
  kubectl label nodes -l pd-config-bench=true pd-config-bench- 2>/dev/null || true
  # Find nodes with AMD GPUs
  NODES=$(kubectl get nodes -o json | python3 -c "
  import json, sys
  data = json.load(sys.stdin)
  for n in data['items']:
      cap = n.get('status', {}).get('capacity', {})
      if cap.get('amd.com/gpu') or cap.get('nvidia.com/gpu'):
          print(n['metadata']['name'])
  ")
  if [ -n "{{MAX_NODES}}" ]; then
    NODES=$(echo "$NODES" | head -n {{MAX_NODES}})
  fi
  COUNT=0
  for node in $NODES; do
    kubectl label node "$node" pd-config-bench=true --overwrite
    COUNT=$((COUNT + 1))
  done
  echo "Labeled $COUNT GPU node(s) for benchmarking"

# Launch a single benchmark Job
_job JOB_NAME TP WORKLOAD_TYPE ISL OSL CONCURRENCY_LEVELS:
  env \
    JOB_NAME={{JOB_NAME}} \
    TP={{TP}} \
    GPU_COUNT={{TP}} \
    MODEL="{{MODEL}}" \
    VLLM_IMAGE="{{IMAGE}}" \
    WORKLOAD_TYPE={{WORKLOAD_TYPE}} \
    ISL={{ISL}} \
    OSL={{OSL}} \
    CONCURRENCY_LEVELS="{{CONCURRENCY_LEVELS}}" \
    TARGET_DURATION={{TARGET_DURATION}} \
    MIN_PROMPTS={{MIN_PROMPTS}} \
    GPU_MEM_UTIL={{GPU_MEM_UTIL}} \
    HF_CACHE_HOST_PATH="{{HF_CACHE}}" \
    envsubst '${JOB_NAME} ${TP} ${GPU_COUNT} ${MODEL} ${VLLM_IMAGE} ${WORKLOAD_TYPE} ${ISL} ${OSL} ${CONCURRENCY_LEVELS} ${TARGET_DURATION} ${MIN_PROMPTS} ${GPU_MEM_UTIL} ${HF_CACHE_HOST_PATH}' \
      < job.yaml | {{KN}} apply -f -

# Launch P/D sweep Jobs (prefill + decode at TP=1,2,4,8)
bench: _setup-nodes
  {{KN}} delete jobs -l app=pd-config-bench,pd-config/workload=prefill --ignore-not-found=true
  {{KN}} delete jobs -l app=pd-config-bench,pd-config/workload=decode --ignore-not-found=true
  just _job pd-config-prefill-tp1 1 prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
  just _job pd-config-prefill-tp2 2 prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
  just _job pd-config-prefill-tp4 4 prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
  just _job pd-config-prefill-tp8 8 prefill {{PREFILL_ISL}} {{PREFILL_OSL}} "{{PREFILL_CONCURRENCIES}}"
  just _job pd-config-decode-tp1 1 decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"
  just _job pd-config-decode-tp2 2 decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"
  just _job pd-config-decode-tp4 4 decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"
  just _job pd-config-decode-tp8 8 decode {{DECODE_ISL}} {{DECODE_OSL}} "{{DECODE_CONCURRENCIES}}"

# Launch aggregated benchmark Jobs (actual workload, no P/D specialization)
bench-agg: _setup-nodes
  {{KN}} delete jobs -l app=pd-config-bench,pd-config/workload=aggregated --ignore-not-found=true
  just _job pd-config-agg-tp1 1 aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"
  just _job pd-config-agg-tp2 2 aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"
  just _job pd-config-agg-tp4 4 aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"
  just _job pd-config-agg-tp8 8 aggregated {{AGG_ISL}} {{AGG_OSL}} "{{AGG_CONCURRENCIES}}"

# Launch all benchmarks (P/D sweep + aggregated)
bench-all:
  just bench
  just bench-agg

# Wait for all benchmark Jobs to complete
wait:
  #!/usr/bin/env bash
  set -euo pipefail
  echo "Waiting for all pd-config benchmark jobs to complete..."
  for job in $({{KN}} get jobs -l app=pd-config-bench -o jsonpath='{.items[*].metadata.name}'); do
    echo "  Waiting for $job..."
    {{KN}} wait --for=condition=complete --timeout=3h "job/$job" || \
      echo "  WARNING: $job did not complete successfully"
  done
  echo "All jobs finished."

# Collect results from completed Jobs and generate CSVs
collect:
  python3 collect.py -n {{NAMESPACE}}

# Collect results and upload to Google Sheets with Pareto charts
collect-sheets TITLE="PD Config Benchmark Results":
  python3 collect.py -n {{NAMESPACE}} --sheets "{{TITLE}}"

# Full workflow: launch P/D sweep, wait, collect results
run:
  just bench
  just wait
  just collect

# Full workflow: all benchmarks (P/D + aggregated), wait, collect
run-all:
  just bench-all
  just wait
  just collect

# Show status of benchmark Jobs and Pods
status:
  {{KN}} get jobs -l app=pd-config-bench

# Clean up all benchmark Jobs
clean:
  {{KN}} delete jobs -l app=pd-config-bench --ignore-not-found=true
